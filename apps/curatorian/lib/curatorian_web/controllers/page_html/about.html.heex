        </div>
        <div class="border rounded-lg p-3">
          <code class="font-mono text-violet-600">schema</code> Schema.org
        </div>
        <div class="border rounded-lg p-3">
          <code class="font-mono text-violet-600">marc21</code> MARC 21
        </div>
        <div class="border rounded-lg p-3">
          <code class="font-mono text-violet-600">mods</code> MODS
        </div>
        <div class="border rounded-lg p-3">
          <code class="font-mono text-violet-600">bf</code> BIBFRAME
        </div>
        <div class="border rounded-lg p-3">
          <code class="font-mono text-violet-600">mets</code> METS
        </div>
        <div class="border rounded-lg p-3">
          <code class="font-mono text-violet-600">onix</code> ONIX
        </div>
        <div class="border rounded-lg p-3">
