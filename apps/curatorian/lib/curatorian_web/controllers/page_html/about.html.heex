        </div>
        <div class="border rounded-lg p-3">
          <code class="font-mono text-violet-600">ead</code> EAD
        </div>
        <div class="border rounded-lg p-3">
          <code class="font-mono text-violet-600">eaccpf</code> EAC-CPF
        </div>
        <div class="border rounded-lg p-3">
          <code class="font-mono text-violet-600">ric</code> RiC
        </div>
        <div class="border rounded-lg p-3">
          <code class="font-mono text-violet-600">premis</code> PREMIS
        </div>
        <div class="border rounded-lg p-3">
          <code class="font-mono text-violet-600">isaar</code> ISAAR(CPF)
        </div>
        <div class="border rounded-lg p-3">
          <code class="font-mono text-violet-600">crm</code> CIDOC CRM
