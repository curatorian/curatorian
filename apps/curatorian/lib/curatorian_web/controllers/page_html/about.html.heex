  <%!-- Daftar Standar Metadata (GLAM) --%>
  <%!-- Menampilkan prefix dan nama singkat standar metadata yang didukung --%>
  <section class="bg-white dark:bg-gray-900 py-12">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center space-y-3 mb-8">
        <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-violet-600 dark:text-violet-400">
          <span class="w-6 h-px bg-violet-400"></span> Standar Metadata
        </span>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white">
