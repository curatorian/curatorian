            <p class="text-sm text-gray-500 dark:text-gray-400">Berbasis di Indonesia</p>
          </div>
          <div class="bg-white dark:bg-gray-900 rounded-xl p-6 text-center space-y-2 border border-violet-100 dark:border-gray-700">
            <p class="text-xl font-bold text-gray-900 dark:text-white">
